# ============================================
# QQ 自动发卡机器人 - 环境配置模板
# 复制为 .env 并填写真实值
# ============================================

# === NoneBot2 基础 ===
DRIVER=~fastapi+~websockets
HOST=0.0.0.0
PORT=18080
SUPERUSERS=["你的QQ号"]
COMMAND_START=["/", ""]
COMMAND_SEP=["."]

# === OneBot 连接 (NapCat WebSocket) ===
ONEBOT_WS_URLS=["ws://127.0.0.1:3011"]

# === 发卡平台账号 (pay.ldxp.cn 有余额的账号) ===
TARGET_SITE_URL=https://pay.ldxp.cn
CONTACT_EMAIL=接收订单通知的邮箱
TARGET_SITE_QUERY_PASSWORD=订单查询安全密码

# 履约模式:
# local_stock = 本地卡密库存发货；用户支付成功后直接扣库存并私聊发货
# manual_payment = Bot 自动生成上游支付宝付款页，你手动付款，再 /检查发货
# manual = 用户付款后只通知管理员，全部手动采购+手动发货
# auto = 全自动余额支付；当前目标站未开放余额支付，不建议启用
ORDER_FULFILLMENT_MODE=local_stock
TARGET_SITE_REQUIRE_BALANCE=false

# auto 模式需要登录目标站时再填写
TARGET_SITE_USERNAME=你的发卡平台用户名
TARGET_SITE_PASSWORD=你的发卡平台密码

# API 直调默认关闭；登录态余额接口抓包确认后再开启
TARGET_SITE_API_ENABLED=false
TARGET_SITE_ORDER_ENDPOINT=/shopApi/Pay/order
TARGET_SITE_QUERY_ENDPOINT=/shopApi/Pay/query
TARGET_SITE_CHANNEL_ID=0
TARGET_SITE_API_PAY_TYPE=

# === 支付配置 (用户付给你的) ===
# 支付宝
ALIPAY_APP_ID=your_alipay_app_id
ALIPAY_PRIVATE_KEY=your_private_key
ALIPAY_PUBLIC_KEY=alipay_public_key

# 微信支付
WECHAT_MCH_ID=your_mch_id
WECHAT_API_KEY=your_api_key

# === AI 客服 (可选, 不填则只用关键词回复) ===
OPENAI_API_KEY=your_openai_api_key
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4o-mini

# === 管理员 ===
ADMIN_QQ=你的QQ号

# === 可选 ===
COUPON_CODE=优惠码(没有留空)

# === 视频报告工作流 ===
# 推荐先本地克隆:
# git clone --depth 1 https://github.com/yt-dlp/yt-dlp.git F:\bot\vendor\yt-dlp
VIDEO_REPORT_YTDLP_REPO=F:\bot\vendor\yt-dlp
VIDEO_REPORT_WORK_DIR=F:\bot\data\video_reports
VIDEO_REPORT_COOKIE_FILE=F:\bot\data\cookies\douyin.txt
VIDEO_REPORT_BROWSER_RESOLVE=true
VIDEO_REPORT_BROWSER_HEADLESS=true
VIDEO_REPORT_BROWSER_TIMEOUT_MS=45000
VIDEO_REPORT_BROWSER_EXECUTABLE_PATH=
VIDEO_REPORT_DOWNLOAD_MEDIA=true
VIDEO_REPORT_KEEP_MEDIA=false
VIDEO_REPORT_WHISPER_MODEL=base
VIDEO_REPORT_MAX_TRANSCRIPT_CHARS=12000
# 连续发送多个链接时的同时生成数量。服务器 CPU 较弱建议 1，想更快可调 2。
VIDEO_REPORT_MAX_CONCURRENCY=1
# 画面识别/OCR。需要 OpenAI 兼容的视觉模型；DeepSeek 文本模型不支持图片时请留空。
VIDEO_REPORT_VISUAL_ANALYSIS=true
VIDEO_REPORT_FRAME_COUNT=3
VIDEO_REPORT_VISION_MODEL=
